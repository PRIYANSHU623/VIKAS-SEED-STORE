# ============================================================
# KRISHISATHI - ENVIRONMENT CONFIGURATION - EXAMPLE FILE
# ============================================================
# Copy this file to .env.development, .env.testing, or .env.production
# and fill in the actual values for each environment.
#
# DO NOT commit this file with actual secrets!
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DATABASE_URL=postgresql://krishiuser:password@localhost:5432/krishisathi
DB_USER=krishiuser
DB_PASSWORD=password
DB_NAME=krishisathi
DB_HOST=localhost
DB_PORT=5433

# ============================================================
# JWT & SECURITY
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# AI & EXTERNAL SERVICES
# ============================================================
GEMINI_API_KEY=your-gemini-api-key
WEATHER_API_KEY=your-weather-api-key
OCR_API_KEY=your-ocr-api-key

# ============================================================
# SERVER CONFIGURATION
# ============================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ============================================================
# CORS & FRONTEND
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000/api

# ============================================================
# DOCKER & DEPLOYMENT
# ============================================================
DOCKER_ENV=false
DOCKER_REGISTRY=
DOCKER_NAMESPACE=
DOCKER_TAG=latest

# ============================================================
# NGINX & REVERSE PROXY
# ============================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=2048

# ============================================================
# FILE UPLOADS
# ============================================================
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ============================================================
# LOGGING
# ============================================================
LOG_DIR=logs
LOG_FILE_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=10
LOG_FORMAT=json  # json or text

# ============================================================
# SECURITY HEADERS
# ============================================================
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
ENABLE_CSP=true
ENABLE_CSRF_PROTECTION=true

# ============================================================
# MONITORING & HEALTH CHECKS
# ============================================================
HEALTH_CHECK_INTERVAL=30
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================
# BACKUP CONFIGURATION
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backups

# ============================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@krishisathi.com

# ============================================================
# AWS/CLOUD STORAGE (Optional)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ============================================================
# SENTRY ERROR TRACKING (Optional)
# ============================================================
SENTRY_DSN=

# ============================================================
# ANALYTICS (Optional)
# ============================================================
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=
